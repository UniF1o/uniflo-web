# API
NEXT_PUBLIC_API_URL=

# Used by `npm run types:api` to locate the OpenAPI spec for type generation.
OPENAPI_SPEC_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=

# Support contact (rendered on non-retryable failure screens). Defaults to
# support@uniflo.co.za when unset.
NEXT_PUBLIC_SUPPORT_EMAIL=

# Basic auth gate (optional). When set, every request requires HTTP Basic Auth.
# Comma-separated list of user:password pairs, e.g. dev:pass1,beta:pass2
# Omit entirely in local development to skip the gate.
BASIC_AUTH_CREDENTIALS=
