# API
NEXT_PUBLIC_API_URL=

# Used by `npm run types:api` to locate the OpenAPI spec for type generation.
# Not read by the Next.js runtime — no NEXT_PUBLIC_ prefix needed.
# Override in your shell when regenerating against a non-local spec:
#   OPENAPI_SPEC_URL=https://api.uniflo.co.za/openapi.json npm run types:api
OPENAPI_SPEC_URL=http://localhost:8000/openapi.json

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
